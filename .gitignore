#Ignore config files
config.json
DEFAULT_CONFIG.json

#Ignore folders
/node_modules/
.vscode/

#Ignore specific file extensions
*.zip
*.db
*.save
*_bk

#Ignore lock files (causes merge conflicts)
package-lock.json

#Ignore large data files
BANS-*.txt

#Ignore core dumps
*.core

#Ignore CPU/heap profiles
*.cpuprofile
*.heapprofile
*.heapsnapshot

# eval.js is intentionally excluded from the repo.
# It must NEVER be deployed in a live/production environment — only use in
# an isolated local dev environment with full trust of all participants.
# If you need to test the eval command, create the file locally but do not
# commit it.
src/commands/eval.js