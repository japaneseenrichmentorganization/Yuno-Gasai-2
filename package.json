{
  "name": "yuno-gasai-2",
  "version": "2.8.0",
  "description": "The remade of Yuno Gasai, flawless & bugless",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --experimental-sqlite index.js",
    "start:legacy": "node index.js",
    "dev": "node --experimental-sqlite index.js --hot-reload",
    "test": "node --test",
    "generate-doc": "jsdoc .\\src -r -p -d docs -t node_modules/docdash",
    "generate-doc-notheme": "jsdoc .\\src -r -p -d docs",
    "check-db": "node --experimental-sqlite src/scripts/db-integrity-check.js",
    "check-db:fix": "node --experimental-sqlite src/scripts/db-integrity-check.js --fix"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "docdash": ">=2.0.2"
  },
  "dependencies": {
    "discord-alt-detector": "^1.0.4",
    "discord.js": "^14.25.1",
    "neo-blessed": "^0.2.0",
    "urban": "^0.3.2"
  },
  "overrides": {
    "undici": ">=6.23.0"
  },
  "optionalDependencies": {
    "bufferutil": ">=4.0.9",
    "utf-8-validate": ">=6.0.5",
    "zlib-sync": ">=0.1.9"
  }
}
